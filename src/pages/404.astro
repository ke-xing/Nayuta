---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';
---

<BaseLayout title="Page Not Found | Nayuta">
  <section class="page-hero reveal">
    <p class="eyebrow">404</p>
    <h1>This page does not exist.</h1>
    <p class="hero-text">
      The link may be outdated, or this entry has not been published yet. Use the navigation below to return.
    </p>
    <div class="hero-actions">
      <a class="button button-primary" href={withBase()}>Go home</a>
      <a class="button button-secondary" href={withBase('/blog/')}>Open journal</a>
    </div>
  </section>
</BaseLayout>
