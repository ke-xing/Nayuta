---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../site.config';
import { withBase } from '../utils/paths';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featuredPost = allPosts.find((post) => post.data.featured) ?? allPosts[0];
const latestPosts = allPosts.filter((post) => post.slug !== featuredPost.slug).slice(0, 2);

const metrics = [
  ['03', '示例文章', '已经内置 Markdown 内容和技术主题结构'],
  ['01', '自动部署链路', '推送到 main 后即可通过 GitHub Actions 发布'],
  ['∞', '长期写作空间', '适合持续沉淀经验、方案复盘和学习笔记'],
];

const principles = [
  {
    title: '偏长期主义',
    detail: '记录那些可以反复复用的工程方法，而不是只追逐短期热点。',
  },
  {
    title: '偏实战细节',
    detail: '每篇文章都鼓励用代码、配置和取舍分析来支撑观点。',
  },
  {
    title: '偏系统思考',
    detail: '把单点技巧放回更大的系统里讨论，避免局部最优。',
  },
];
---

<BaseLayout>
  <section class="hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">PERSONAL TECH BLOG / GITHUB PAGES READY</p>
      <h1>把工程实践写成可以复用的经验。</h1>
      <p class="hero-text">
        {siteMeta.title} 是一个面向长期积累的个人技术博客模板，适合持续发布前端工程化、系统设计、
        AI 协作流和日常研发方法论。
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={withBase('/blog/')}>阅读博客</a>
        <a class="button button-secondary" href={siteMeta.github} target="_blank" rel="noreferrer">
          查看 GitHub
        </a>
      </div>
    </div>

    <div class="hero-panel panel">
      <p class="panel-label">CURRENT FOCUS</p>
      <ul class="focus-list">
        {siteMeta.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="stats-grid reveal" aria-label="站点亮点">
    {metrics.map(([value, label, detail]) => (
      <article class="metric-card panel">
        <span class="metric-value">{value}</span>
        <h2>{label}</h2>
        <p>{detail}</p>
      </article>
    ))}
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FEATURED NOTE</p>
        <h2>本周主打文章</h2>
      </div>
      <a class="text-link" href={withBase('/blog/')}>查看全部文章</a>
    </div>

    <PostCard post={featuredPost} featured={true} />
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">LATEST WRITING</p>
        <h2>最近发布</h2>
      </div>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">EDITORIAL PRINCIPLES</p>
        <h2>写作取向</h2>
      </div>
    </div>

    <div class="principle-grid">
      {principles.map((item) => (
        <article class="principle-card panel">
          <h3>{item.title}</h3>
          <p>{item.detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
