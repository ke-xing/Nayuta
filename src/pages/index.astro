---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../site.config';
import { withBase } from '../utils/paths';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featuredPost = allPosts.find((post) => post.data.featured) ?? allPosts[0];
const latestPosts = allPosts.filter((post) => post.slug !== featuredPost.slug).slice(0, 2);

const metrics = [
  ['01', '博客已上线', '项目已经接入 GitHub Pages 自动部署，后续写完就能直接发。'],
  ['03', '起步文章', '先把开站说明、技术选型和写作计划沉淀下来。'],
  ['2026', '持续更新中', '这里会逐步记录开发过程、工具使用和个人项目复盘。'],
];

const principles = [
  {
    title: '把过程写清楚',
    detail: '不仅记录结论，也把当时的背景、取舍和踩坑过程一起留下来。',
  },
  {
    title: '把实践写具体',
    detail: '尽量用代码、配置和真实场景复盘，而不是停留在抽象观点里。',
  },
  {
    title: '把积累做长期',
    detail: '希望这个站点慢慢变成一份能持续回看的个人技术档案。',
  },
];
---

<BaseLayout>
  <section class="hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">KE-XING / TECH NOTES / BUILT WITH ASTRO</p>
      <h1>记录我正在构建的东西，也记录它为什么这样构建。</h1>
      <p class="hero-text">
        {siteMeta.title} 是我的个人技术博客。这里会持续更新前端开发、自动化脚本、AI 工具协作、
        以及个人项目从想法到落地的过程记录。
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={withBase('/blog/')}>阅读博客</a>
        <a class="button button-secondary" href={siteMeta.github} target="_blank" rel="noreferrer">
          查看 GitHub
        </a>
      </div>
    </div>

    <div class="hero-panel panel">
      <p class="panel-label">CURRENT FOCUS</p>
      <ul class="focus-list">
        {siteMeta.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="stats-grid reveal" aria-label="站点亮点">
    {metrics.map(([value, label, detail]) => (
      <article class="metric-card panel">
        <span class="metric-value">{value}</span>
        <h2>{label}</h2>
        <p>{detail}</p>
      </article>
    ))}
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FEATURED NOTE</p>
        <h2>从这篇开始认识这个站点</h2>
      </div>
      <a class="text-link" href={withBase('/blog/')}>查看全部文章</a>
    </div>

    <PostCard post={featuredPost} featured={true} />
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">LATEST WRITING</p>
        <h2>最新更新</h2>
      </div>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">EDITORIAL PRINCIPLES</p>
        <h2>我希望这里慢慢长成的样子</h2>
      </div>
    </div>

    <div class="principle-grid">
      {principles.map((item) => (
        <article class="principle-card panel">
          <h3>{item.title}</h3>
          <p>{item.detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
