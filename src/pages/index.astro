---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../site.config';
import { withBase } from '../utils/paths';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featuredPost = allPosts.find((post) => post.data.featured) ?? allPosts[0];
const latestPosts = allPosts.filter((post) => post.slug !== featuredPost.slug).slice(0, 2);

const metrics = [
  ['01', 'Production-ready publishing', 'Push to main and GitHub Pages deploys the site automatically.'],
  ['03', 'Editorial pillars', 'Engineering systems, AI workflows, and product-level execution.'],
  ['Infinite', 'Long-horizon archive', 'A living record of decisions, tradeoffs, and reusable patterns.'],
];

const principles = [
  {
    title: 'Precision before noise',
    detail: 'Every note favors clear reasoning, measurable outcomes, and practical execution detail.',
  },
  {
    title: 'Systems-level perspective',
    detail: 'Local optimizations are useful only when they strengthen the architecture as a whole.',
  },
  {
    title: 'Elegance through restraint',
    detail: 'The best technical work is often quiet: simple interfaces, disciplined decisions, durable code.',
  },
];
---

<BaseLayout>
  <section class="hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">PRIVATE PUBLICATION / KE-XING / SOFTWARE CRAFT</p>
      <h1>Technology writing for leaders who care about craft.</h1>
      <p class="hero-text">
        {siteMeta.title} is a curated technical journal where I publish high-signal notes on product engineering,
        architecture, and AI-enabled execution. The goal is not volume. The goal is clarity.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={withBase('/blog/')}>Read Journal</a>
        <a class="button button-secondary" href={siteMeta.github} target="_blank" rel="noreferrer">
          View GitHub
        </a>
      </div>
    </div>

    <aside class="hero-panel panel">
      <p class="panel-label">Current Focus</p>
      <ul class="focus-list">
        {siteMeta.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </section>

  <section class="stats-grid reveal" aria-label="Site highlights">
    {metrics.map(([value, label, detail]) => (
      <article class="metric-card panel">
        <span class="metric-value">{value}</span>
        <h2>{label}</h2>
        <p>{detail}</p>
      </article>
    ))}
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FEATURED NOTE</p>
        <h2>Start here</h2>
      </div>
      <a class="text-link" href={withBase('/blog/')}>Browse all entries</a>
    </div>

    <PostCard post={featuredPost} featured={true} />
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">LATEST WRITING</p>
        <h2>Recent publications</h2>
      </div>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-heading">
      <div>
        <p class="eyebrow">EDITORIAL PRINCIPLES</p>
        <h2>What this journal optimizes for</h2>
      </div>
    </div>

    <div class="principle-grid">
      {principles.map((item) => (
        <article class="principle-card panel">
          <h3>{item.title}</h3>
          <p>{item.detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
