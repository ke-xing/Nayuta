---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../site.config';
import { slugifyCategory } from '../utils/category';
import { withBase } from '../utils/paths';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const categories = Array.from(new Set(allPosts.map((post) => post.data.category))).sort((a, b) =>
  a.localeCompare(b),
);
const years = Array.from(new Set(allPosts.map((post) => String(post.data.publishDate.getFullYear())))).sort(
  (a, b) => Number(b) - Number(a),
);
const profile = siteMeta.profile as typeof siteMeta.profile & {
  location?: string;
  links?: string[];
};
const profileLinks = profile.links ?? [];
---

<BaseLayout>
  <div class="home-layout">
    <aside class="home-sidebar reveal">
      <section class="intro-panel">
        <div class="intro-head">
          <img
            class="intro-avatar"
            src={withBase('/avatar.jpg')}
            alt="Avatar of ke-xing"
            width="92"
            height="92"
            loading="eager"
            decoding="async"
          />
          <div class="intro-head-copy">
            <p class="intro-kicker">PERSONAL PROFILE</p>
            <h2 class="intro-title">{profile.name}</h2>
          </div>
        </div>
        <p class="intro-summary">{profile.intro}</p>
        <p class="intro-summary">{profile.summary}</p>

        <div class="intro-meta">
          {profile.location && <span>{profile.location}</span>}
          {profileLinks.map((item) => <span>{item}</span>)}
        </div>
      </section>

      <section class="filter-bar" aria-label="Article filters">
        <div class="filter-controls">
          <label class="filter-field" for="year-filter">
            <span class="filter-label">Year</span>
            <select id="year-filter" class="filter-select">
              <option value="all">All years</option>
              {years.map((year) => <option value={year}>{year}</option>)}
            </select>
          </label>

          <label class="filter-field" for="category-filter">
            <span class="filter-label">Category</span>
            <select id="category-filter" class="filter-select">
              <option value="all">All categories</option>
              {categories.map((category) => (
                <option value={slugifyCategory(category)}>{category}</option>
              ))}
            </select>
          </label>

          <button id="reset-filter" class="filter-reset" type="button">
            Reset
          </button>
        </div>

        <p class="filter-status" id="filter-status">Showing {allPosts.length} articles</p>
      </section>
    </aside>

    <section class="home-feed reveal">
      <ul class="post-feed" id="post-feed">
        {allPosts.map((post) => (
          <li
            class="feed-item"
            data-post-item
            data-year={post.data.publishDate.getFullYear()}
            data-category={slugifyCategory(post.data.category)}
          >
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    </section>
  </div>

  <script is:inline>
    const yearFilter = document.querySelector('#year-filter');
    const categoryFilter = document.querySelector('#category-filter');
    const resetButton = document.querySelector('#reset-filter');
    const status = document.querySelector('#filter-status');
    const items = Array.from(document.querySelectorAll('[data-post-item]'));
    const total = items.length;

    const params = new URLSearchParams(window.location.search);
    const initialYear = params.get('year') ?? 'all';
    const initialCategory = params.get('category') ?? 'all';

    if (yearFilter) yearFilter.value = initialYear;
    if (categoryFilter) categoryFilter.value = initialCategory;

    const updateStatus = (count) => {
      if (!status) return;
      status.textContent = count === total ? `Showing all ${total} articles` : `Showing ${count} of ${total} articles`;
    };

    const updateUrl = (year, category) => {
      const next = new URLSearchParams(window.location.search);
      if (year === 'all') next.delete('year');
      else next.set('year', year);

      if (category === 'all') next.delete('category');
      else next.set('category', category);

      const query = next.toString();
      const url = query ? `${window.location.pathname}?${query}` : window.location.pathname;
      window.history.replaceState({}, '', url);
    };

    const applyFilters = () => {
      const year = yearFilter ? yearFilter.value : 'all';
      const category = categoryFilter ? categoryFilter.value : 'all';
      let visible = 0;

      items.forEach((item) => {
        const yearMatch = year === 'all' || item.dataset.year === year;
        const categoryMatch = category === 'all' || item.dataset.category === category;
        const show = yearMatch && categoryMatch;
        item.hidden = !show;
        if (show) visible += 1;
      });

      updateStatus(visible);
      updateUrl(year, category);
    };

    yearFilter?.addEventListener('change', applyFilters);
    categoryFilter?.addEventListener('change', applyFilters);
    resetButton?.addEventListener('click', () => {
      if (yearFilter) yearFilter.value = 'all';
      if (categoryFilter) categoryFilter.value = 'all';
      applyFilters();
    });

    applyFilters();
  </script>
</BaseLayout>
