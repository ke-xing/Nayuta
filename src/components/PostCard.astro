---
import type { CollectionEntry } from 'astro:content';
import { slugifyCategory } from '../utils/category';
import { formatDate } from '../utils/date';
import { withBase } from '../utils/paths';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const postHref = withBase(`/blog/${post.slug}/`);
const categorySlug = slugifyCategory(post.data.category);
const categoryHref = withBase(`/blog/category/${categorySlug}/`);
---

<article class="post-card">
  <div class="post-card-topline">
    <span>{formatDate(post.data.publishDate)}</span>
    <span>{post.data.readingTime ?? '5 min'}</span>
  </div>

  <h3>
    <a href={postHref}>{post.data.title}</a>
  </h3>

  <p class="post-summary">{post.data.summary}</p>

  <div class="post-card-footer">
    <a class="category-chip" href={categoryHref}>
      {post.data.category}
    </a>
    <a class="text-link" href={postHref}>
      Read article
    </a>
  </div>
</article>
