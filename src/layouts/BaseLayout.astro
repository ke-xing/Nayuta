---
import '../styles/global.css';
import { siteMeta } from '../site.config';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = `${siteMeta.title} | ${siteMeta.subtitle}`,
  description = siteMeta.description,
  pageClass = '',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const normalizePath = (value: string) => (value.endsWith('/') ? value : `${value}/`);
const currentPath = normalizePath(Astro.url.pathname);
const visitorMapId =
  ((siteMeta as typeof siteMeta & { analytics?: { visitorMapId?: string } }).analytics?.visitorMapId ??
    'ke-xing-nayuta-visitors')
    .trim() || 'ke-xing-nayuta-visitors';
const visitorMapSrc = `https://clustrmaps.com/map_v2.js?cl=ffffff&w=360&t=n&d=${encodeURIComponent(visitorMapId)}&co=f8fafd&cmo=34a853&cmn=ea4335&ct=5f6368`;
const navItems = [
  { label: 'Home', href: withBase(), external: false },
  { label: 'Journal', href: withBase('/blog/'), external: false },
  { label: 'GitHub', href: siteMeta.github, external: true },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    {canonical && <link rel="canonical" href={canonical} />}
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#content">Skip to content</a>

    <div class="site-backdrop" aria-hidden="true">
      <div class="texture"></div>
      <div class="halo halo-a"></div>
      <div class="halo halo-b"></div>
      <div class="rule-lines"></div>
    </div>

    <div class="page-shell">
      <header class="topbar reveal">
        <nav class="main-nav" aria-label="Primary">
          {navItems.map((item) => {
            const itemPath = item.external ? '' : normalizePath(item.href);
            const isActive =
              !item.external &&
              (item.label === 'Home' ? currentPath === itemPath : currentPath.startsWith(itemPath));

            return (
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </header>

      <main id="content">
        <slot />
      </main>

      <footer class="footer-note">
        <p>
          (c) {new Date().getFullYear()} {siteMeta.author}. Crafted with Astro and deployed on GitHub Pages.
        </p>
      </footer>

      <section class="visitor-insights reveal" aria-label="Visitor insights">
        <div class="visitor-head">
          <p class="eyebrow">VISITOR INSIGHTS</p>
          <h2>Global Reach</h2>
        </div>

        <div class="visitor-grid">
          <section class="visitor-stats panel" aria-label="Traffic statistics">
            <p class="visitor-stats-title">Traffic overview</p>
            <div class="visitor-stat" id="busuanzi_container_site_uv">
              <span class="visitor-label">Visitors</span>
              <strong id="busuanzi_value_site_uv">--</strong>
            </div>
            <div class="visitor-stat" id="busuanzi_container_site_pv">
              <span class="visitor-label">Page views</span>
              <strong id="busuanzi_value_site_pv">--</strong>
            </div>
          </section>

          <section class="visitor-map panel" aria-label="Visitor map">
            <p class="visitor-map-title">Visit locations</p>
            <div class="visitor-map-canvas">
              <script is:inline async id="clustrmaps" src={visitorMapSrc}></script>
            </div>
            <p class="visitor-map-note">Map updates with recent visits.</p>
          </section>
        </div>

        <script
          is:inline
          async
          src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"
        ></script>
      </section>
    </div>
  </body>
</html>
