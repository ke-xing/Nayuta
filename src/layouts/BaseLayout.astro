---
import '../styles/global.css';
import { siteMeta } from '../site.config';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = `${siteMeta.title} | ${siteMeta.subtitle}`,
  description = siteMeta.description,
  pageClass = '',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const navItems = [
  { label: 'Home', href: withBase() },
  { label: 'Journal', href: withBase('/blog/') },
  { label: 'GitHub', href: siteMeta.github },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    {canonical && <link rel="canonical" href={canonical} />}
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#content">Skip to content</a>

    <div class="site-backdrop" aria-hidden="true">
      <div class="texture"></div>
      <div class="halo halo-a"></div>
      <div class="halo halo-b"></div>
      <div class="rule-lines"></div>
    </div>

    <div class="page-shell">
      <header class="topbar reveal">
        <a class="brand" href={withBase()}>
          <span class="brand-mark">N</span>
          <span class="brand-copy">
            <strong>{siteMeta.title}</strong>
            <small>{siteMeta.subtitle}</small>
          </span>
        </a>

        <nav class="main-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              target={item.label === 'GitHub' ? '_blank' : undefined}
              rel={item.label === 'GitHub' ? 'noreferrer' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </header>

      <main id="content">
        <slot />
      </main>

      <footer class="footer-note">
        <p>
          (c) {new Date().getFullYear()} {siteMeta.author}. Crafted with Astro and deployed on GitHub Pages.
        </p>
      </footer>
    </div>
  </body>
</html>
